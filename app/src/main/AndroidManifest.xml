<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" tools:node="remove" />

    <!-- Required to read un-redacted GPS metadata from picker-selected videos via
         MediaStore.setRequireOriginal. Without it, METADATA_KEY_LOCATION comes back
         blank for items reached through the photo picker, and we'd strip GPS on
         every compress — defeating the archive workflow. -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <!-- Needed to (a) convert photo-picker URIs to real MediaStore URIs via
         MediaStore.getMediaUri, which is the only thing createDeleteRequest
         accepts, and (b) keep ACCESS_MEDIA_LOCATION un-redacted on the
         picker path. Without READ_MEDIA_VIDEO the in-place "Replace
         originals" toggle silently no-ops because we never get a deletable
         URI to hand to the system dialog. -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <!-- Foreground service group, all for the same job: pinning the process
         alive while a batch transcode runs so Android's Doze / app-standby
         heuristics don't suspend Media3 mid-encode when the user locks the
         screen or switches apps. The mediaProcessing service type is the
         Android-14+ category explicitly designed for "transcode media in
         the background" with a 6h-per-session cap (we never come close).
         POST_NOTIFICATIONS is a runtime grant on Android 13+ and is what
         lets us show the persistent progress notification + cancel button. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROCESSING" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Compressor">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Compressor">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
            <!-- Handle a single shared video. Other apps' Share sheet ACTION_SEND
                 with a video/* payload routes here. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="video/*" />
            </intent-filter>

            <!-- Handle multiple shared videos (e.g. share sheet "select multiple"
                 → Tinyd). Routes into the same batch queue the in-app
                 picker uses. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="video/*" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

        <service
            android:name=".CompressionService"
            android:exported="false"
            android:foregroundServiceType="mediaProcessing" />
    </application>

</manifest>